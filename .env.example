# ================================
# Application Configuration
# ================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# ================================
# Coinbase Developer Platform (CDP)
# ================================
# Get CDP API credentials from:
# 1. Visit https://portal.cdp.coinbase.com
# 2. Create a new project
# 3. Navigate to API Keys section
# 4. Generate new API key and save the ID and Secret
CDP_API_KEY_ID=your-cdp-api-key-id-here
CDP_API_KEY_SECRET=your-cdp-api-key-secret-here

# Get CDP Project ID from:
# Same CDP portal, found in project settings
NEXT_PUBLIC_CDP_PROJECT_ID=your-cdp-project-id-here

# ================================
# Fal.ai API (Image Processing)
# ================================
# Get your fal.ai API key from:
# 1. Sign up at https://fal.ai
# 2. Navigate to Dashboard > API Keys
# 3. Generate a new API key
FAL_KEY=your-fal-api-key-here

# ================================
# Upstash Redis (Rate Limiting)
# ================================
# Get Upstash Redis credentials from:
# 1. Sign up at https://upstash.com
# 2. Create a new Redis database
# 3. Copy credentials from database details page

# Primary Redis URL (TLS enabled)
KV_URL=rediss://default:<password>@<your-database>.upstash.io:6379
REDIS_URL=rediss://default:<password>@<your-database>.upstash.io:6379

# REST API credentials for Upstash
KV_REST_API_URL=https://<your-database>.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-api-token
KV_REST_API_READ_ONLY_TOKEN=your-upstash-read-only-token

# ================================
# x402 Payment Protocol (Base Network)
# ================================
# Network configuration for blockchain payments
# Options: "base" (mainnet) or "base-sepolia" (testnet)
NEXT_PUBLIC_NETWORK=base

# Base Mainnet Chain ID (use 84532 for base-sepolia testnet)
NEXT_PUBLIC_CHAIN_ID=8453

# USDC Contract Address on Base
# Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# x402 Facilitator URL (payment processor)
# Production: https://api.x402.org/facilitator
# Alternative: https://facilitator.x402.rs
FACILITATOR_URL=https://api.x402.org/facilitator

# ================================
# Payment Wallet
# ================================
# Your wallet address that will receive payments
# Get this from your crypto wallet (MetaMask, Coinbase Wallet, etc.)
# Must be a valid Ethereum address on Base network
RECIPIENT_WALLET_ADDRESS=0xYourWalletAddressHere

# ================================
# WalletConnect
# ================================
# Get WalletConnect credentials from:
# 1. Visit https://cloud.walletconnect.com
# 2. Create a new project
# 3. Copy the Project ID and Secret from dashboard
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id-here
WALLETCONNECT_SECRET=your-walletconnect-secret-here
